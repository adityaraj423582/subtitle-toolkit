# Copy this file to .env.local and fill in real values when ready.
# Nothing here is required for the site to build or run — every feature
# gated by these variables simply stays off until a value is provided.

# Google Analytics 4 measurement ID (e.g. "G-XXXXXXXXXX").
# Leave unset to skip loading Google Analytics entirely.
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher/client ID (e.g. "ca-pub-XXXXXXXXXXXXXXXX").
# Leave unset and the AdSlot component renders nothing.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Canonical production URL, used for the sitemap, robots.txt, metadataBase,
# and OG/canonical/JSON-LD tags. Set this to the real production domain once
# it's purchased (e.g. "https://subtitletoolkit.com") — no trailing slash.
#
# Leave unset otherwise: on Vercel it automatically falls back to
# `https://${VERCEL_URL}` (the actual deployment URL Vercel provides), and
# locally it falls back to http://localhost:3000. See src/lib/site-config.ts.
NEXT_PUBLIC_SITE_URL=
